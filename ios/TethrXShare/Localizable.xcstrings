    "optional — e.g. summarize this, or fix this error": {
      "extractionState": "manual",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "facultatif — ex. : résumer ceci, ou corriger cette erreur"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "opcional — p. ej. resumir esto o corregir este error"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "optional — z. B. das zusammenfassen oder diesen Fehler beheben"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "facoltativo, es. riassumi questo o correggi questo errore"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "opcional — ex.: resuma isto ou corrija este erro"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "任意（例: これを要約、このエラーを修正）"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可选，例如：总结一下，或修复这个错误"
          }
        }
      }
    },
