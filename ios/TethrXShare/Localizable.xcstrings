    "Open TethrX and pair with your computer, then share again.": {
      "extractionState": "manual",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvrez TethrX et appairez votre ordinateur, puis partagez à nouveau."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abra TethrX y empareje con su ordenador; después, comparta de nuevo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Öffnen Sie TethrX, koppeln Sie mit Ihrem Computer und teilen Sie erneut."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apra TethrX e abbini il suo computer, poi condivida di nuovo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Abra o TethrX e pareie com seu computador, depois compartilhe novamente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "TethrXを開いてパソコンとペアリングし、もう一度共有してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开 TethrX 与你的电脑配对，然后重新分享。"
          }
        }
      }
    },
