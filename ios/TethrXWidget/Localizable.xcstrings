    "Whether your computer's Grok is working, and what it's cost.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si le Grok de votre ordinateur travaille, et ce qu'il a coûté."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si Grok está trabajando en tu computadora y cuánto ha costado."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ob Grok auf Ihrem Computer arbeitet und was es gekostet hat."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se il Grok del tuo computer sta lavorando e quanto è costato."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Se o Grok do seu computador está trabalhando e quanto custou."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コンピュータのGrokが作業中かどうかと、これまでのコスト。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您电脑上的 Grok 是否在工作，以及已花费的成本。"
          }
        }
      }
    },
