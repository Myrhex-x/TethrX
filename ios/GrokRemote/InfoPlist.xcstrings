{
  "sourceLanguage": "en",
  "version": "1.0",
  "strings": {
    "NSCameraUsageDescription": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Scannez le QR code d'appairage affiché par le bridge sur votre ordinateur pour vous connecter."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Escanea el código QR de emparejamiento que muestra el bridge en tu computadora para conectar."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Scannen Sie den Kopplungs-QR-Code, den die Bridge auf Ihrem Computer anzeigt, um sich zu verbinden."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scansiona il codice QR di abbinamento mostrato dal bridge sul tuo computer per connetterti."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escaneie o código QR de pareamento exibido pelo bridge no seu computador para conectar."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "接続するには、コンピュータのブリッジが表示するペアリングQRコードをスキャンします。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "扫描电脑上桥接程序显示的配对二维码以进行连接。"
          }
        }
      }
    },
    "NSMicrophoneUsageDescription": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dictez vos messages à Grok avec votre voix."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dicta mensajes a Grok con tu voz."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diktieren Sie Grok Nachrichten mit Ihrer Stimme."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Detta i messaggi a Grok con la tua voce."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Dite mensagens para o Grok com sua voz."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声でGrokへのメッセージを入力します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用语音向 Grok 口述消息。"
          }
        }
      }
    },
    "NSSpeechRecognitionUsageDescription": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Transcrit votre dictée en texte à envoyer à Grok."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Transcribe tu voz a texto para enviarlo a Grok."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wandelt Ihre Diktate in Text für Grok um."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Trascrive la tua voce in testo da inviare a Grok."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Transcreve sua voz em texto para enviar ao Grok."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "話した内容をテキストに変換してGrokに送信します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将您的语音转写为文字并发送给 Grok。"
          }
        }
      }
    },
    "NSFaceIDUsageDescription": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Déverrouillez TethrX avec Face ID, car il peut exécuter des commandes sur votre ordinateur."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desbloquea TethrX con Face ID, ya que puede ejecutar comandos en tu computadora."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entsperren Sie TethrX mit Face ID, da es Befehle auf Ihrem Computer ausführen kann."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sblocca TethrX con Face ID, poiché può eseguire comandi sul tuo computer."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desbloqueie o TethrX com Face ID, já que ele pode executar comandos no seu computador."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "TethrXはコンピュータ上でコマンドを実行できるため、Face IDでロックを解除します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用面容 ID 解锁 TethrX，因为它可以在您的电脑上运行命令。"
          }
        }
      }
    },
    "NSLocalNetworkUsageDescription": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "TethrX se connecte au bridge qui tourne sur votre ordinateur via votre réseau local."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "TethrX se conecta al bridge que se ejecuta en tu computadora a través de tu red local."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "TethrX verbindet sich über Ihr lokales Netzwerk mit der Bridge auf Ihrem Computer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "TethrX si connette al bridge in esecuzione sul tuo computer tramite la rete locale."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O TethrX se conecta ao bridge em execução no seu computador pela rede local."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "TethrXはローカルネットワーク経由で、コンピュータ上のブリッジに接続します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "TethrX 通过本地网络连接到您电脑上运行的桥接程序。"
          }
        }
      }
    }
  }
}