          }
        }
      }
    },
    "Get it from the Mac App Store or tailscale.com/download. Once you're signed in, a menu-bar icon shows it's connected.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Laden Sie es aus dem Mac App Store oder von tailscale.com/download. Sobald Sie angemeldet sind, zeigt ein Symbol in der Menüleiste die Verbindung an."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Descárgalo del Mac App Store o de tailscale.com/download. Cuando inicies sesión, un icono en la barra de menús indica que está conectado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Disponible sur le Mac App Store ou tailscale.com/download. Une fois connecté, une icône dans la barre des menus confirme la connexion."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scaricalo dal Mac App Store o da tailscale.com/download. Una volta effettuato l'accesso, un'icona nella barra dei menu mostra che è connesso."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac App Store または tailscale.com/download から入手してください。サインインすると、メニューバーのアイコンで接続中であることを確認できます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Baixe na Mac App Store ou em tailscale.com/download. Depois de iniciar sessão, um ícone na barra de menus mostra que está conectado."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可从 Mac App Store 或 tailscale.com/download 获取。登录后，菜单栏图标会显示已连接。"
          }
        }
      }
    },
