    "Couldn't reach that computer. Check the address and that its bridge is running.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Computer ist nicht erreichbar. Prüfen Sie die Adresse und ob seine Bridge läuft."
          }
        },
        "es": {
