            "state": "translated",
            "value": "Nom"
          }
        }
      }
    },
    "Folder name": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nom du dossier"
          }
        }
      }
    },
    "Save": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Enregistrer"
          }
        }
      }
    },
    "Cancel": {
