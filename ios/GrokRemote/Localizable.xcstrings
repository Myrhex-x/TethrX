    "Adding a computer switches to it. Your other computers stay paired — swap between them any time.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein hinzugefügter Computer wird direkt aktiv. Ihre anderen Computer bleiben gekoppelt — Sie können jederzeit zwischen ihnen wechseln."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Al añadir un ordenador se cambia a él. Los demás siguen enlazados — cambia entre ellos cuando quieras."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajouter un ordinateur bascule dessus. Les autres restent appairés — changez à tout moment."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungendo un computer si passa a quello. Gli altri restano abbinati — puoi passare dall'uno all'altro in qualsiasi momento."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コンピュータを追加すると、そのコンピュータに切り替わります。ほかのコンピュータもペアリングされたまま残るので、いつでも切り替えられます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicionar um computador troca para ele. Seus outros computadores continuam pareados — alterne entre eles a qualquer momento."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加电脑后会切换到它。其他电脑仍保持配对——可随时切换。"
          }
        }
      }
    },
    "Already installed? Check with  grok --version  and skip ahead.": {
      "localizations": {
        "de": {
          "stringUnit": {
