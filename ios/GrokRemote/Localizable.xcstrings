    "Tailscale is a free private network that links this phone to your computer from anywhere. Install it on your computer, then sign in to create a free account — you can use Google, Apple, GitHub, or email.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale ist ein kostenloses privates Netzwerk, das dieses iPhone von überall mit Ihrem Computer verbindet. Installieren Sie es auf Ihrem Computer und melden Sie sich an, um einen kostenlosen Account zu erstellen — mit Google, Apple, GitHub oder E-Mail."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale es una red privada gratuita que conecta este teléfono con tu ordenador desde cualquier lugar. Instálalo en tu ordenador y luego inicia sesión para crear una cuenta gratuita — puedes usar Google, Apple, GitHub o el correo electrónico."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale est un réseau privé gratuit qui relie ce téléphone à votre ordinateur depuis n'importe où. Installez-le sur votre ordinateur, puis connectez-vous pour créer un compte gratuit — avec Google, Apple, GitHub ou un e-mail."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale è una rete privata gratuita che collega questo telefono al tuo computer ovunque tu sia. Installalo sul tuo computer, poi accedi per creare un account gratuito — puoi usare Google, Apple, GitHub o l'email."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale は、この iPhone とコンピュータをどこからでもつなぐ無料のプライベートネットワークです。まずコンピュータにインストールし、サインインして無料アカウントを作成してください — Google、Apple、GitHub、またはメールアドレスが使えます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Tailscale é uma rede privada gratuita que conecta este telefone ao seu computador de qualquer lugar. Instale-o no seu computador e inicie sessão para criar uma conta gratuita — você pode usar Google, Apple, GitHub ou e-mail."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale 是一个免费的私有网络，可让这台手机随时随地连接你的电脑。先在电脑上安装，然后登录以创建免费账户——可使用 Google、Apple、GitHub 或电子邮件。"
          }
        }
      }
    },
