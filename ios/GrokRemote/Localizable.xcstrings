    "Counted on your computer, from what Grok reports for each turn. Cost is Grok's own estimate, not billing data from your xAI account.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Comptabilisé sur votre ordinateur, d'après ce que Grok indique à chaque tour. Le coût est une estimation de Grok, pas les données de facturation de votre compte xAI."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se cuenta en su ordenador, a partir de lo que Grok informa en cada turno. El coste es una estimación del propio Grok, no datos de facturación de su cuenta de xAI."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Auf Ihrem Computer gezählt, anhand der Angaben von Grok zu jeder Runde. Die Kosten sind Groks eigene Schätzung, keine Abrechnungsdaten aus Ihrem xAI-Konto."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Calcolato sul suo computer, in base a quanto Grok riporta per ogni turno. Il costo è una stima di Grok, non un dato di fatturazione del suo account xAI."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Contabilizado no seu computador, a partir do que o Grok informa em cada turno. O custo é uma estimativa do próprio Grok, não dados de cobrança da sua conta xAI."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "各ターンについてGrokが報告した内容をもとに、パソコン上で集計しています。コストはGrok自身の推定値で、xAIアカウントの請求データではありません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在你的电脑上统计，数据来自 Grok 每轮的报告。费用是 Grok 自己的估算，不是你 xAI 账户的账单数据。"
          }
        }
      }
    },
