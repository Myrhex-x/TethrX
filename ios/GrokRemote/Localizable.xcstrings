          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "任务在此会话中运行——沿用该会话的文件夹、推理强度和批准设置。"
          }
        }
      }
    },
    "The working tree is clean%@.": {
      "localizations": {
