    },
    "New sessions run Grok in this folder. Plan mode, effort, and approvals are set inside each session.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Neue Sessions führen Grok in diesem Ordner aus. Planmodus, Aufwand und Genehmigungen werden in der jeweiligen Session festgelegt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las sesiones nuevas ejecutan Grok en esta carpeta. El modo plan, el esfuerzo y las aprobaciones se configuran dentro de cada sesión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les nouvelles sessions lancent Grok dans ce dossier. Le mode plan, l'effort et les approbations se règlent dans chaque session."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le nuove sessioni eseguono Grok in questa cartella. Modalità piano, sforzo e approvazioni si impostano all'interno di ogni sessione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "新規セッションはこのフォルダで Grok を実行します。プランモード、推論強度、承認は各セッション内で設定します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Novas sessões executam o Grok nesta pasta. Modo de plano, esforço e aprovações são definidos dentro de cada sessão."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "新会话会在此文件夹中运行 Grok。计划模式、推理强度和批准方式在每个会话内单独设置。"
          }
        }
      }
    },
