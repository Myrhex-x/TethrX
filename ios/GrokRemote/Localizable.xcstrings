    },
    "This phone is already paired. Reconnect to the same computer — or set it up again below.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses iPhone ist bereits gekoppelt. Verbinden Sie sich erneut mit demselben Computer — oder richten Sie unten alles neu ein."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este teléfono ya está enlazado. Reconéctate al mismo ordenador — o configúralo de nuevo abajo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce téléphone est déjà appairé. Reconnectez-vous au même ordinateur — ou refaites la configuration ci-dessous."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo telefono è già abbinato. Riconnettiti allo stesso computer — oppure configuralo di nuovo qui sotto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この iPhone はペアリング済みです。同じコンピュータに再接続するか、下からもう一度設定してください。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este telefone já está pareado. Reconecte-se ao mesmo computador — ou configure de novo abaixo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这台手机已配对。可重新连接同一台电脑——或在下方重新设置。"
