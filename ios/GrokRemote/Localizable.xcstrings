    "Found on your network. Tap to fill the address — then enter that computer's token.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "In Ihrem Netzwerk gefunden. Tippen Sie, um die Adresse zu übernehmen — geben Sie dann den Token dieses Computers ein."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Encontrado en tu red. Toca para rellenar la dirección — luego introduce el token de ese ordenador."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Trouvés sur votre réseau. Touchez pour remplir l'adresse — puis saisissez le jeton de cet ordinateur."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Trovato sulla tua rete. Tocca per compilare l'indirizzo — poi inserisci il token di quel computer."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ネットワーク上で見つかりました。タップするとアドレスが入力されます — あとはそのコンピュータのトークンを入力してください。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Encontrado na sua rede. Toque para preencher o endereço — depois insira o token desse computador."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在你的网络上发现。点按以填入地址——然后输入那台电脑的令牌。"
          }
        }
      }
    },
