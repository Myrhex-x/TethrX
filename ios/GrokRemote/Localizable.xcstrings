            "value": "Grok travaille sur %@%@."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok sta lavorando a %@%@."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
