    "Requires an APNs key configured on your bridge. Delivered to this phone when it isn't actively watching a session.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erfordert einen auf Ihrer Bridge konfigurierten APNs-Schlüssel. Wird an dieses iPhone zugestellt, wenn es gerade keine Session aktiv beobachtet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Requiere una clave APNs configurada en tu bridge. Se entregan a este teléfono cuando no está viendo activamente una sesión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nécessite une clé APNs configurée sur votre bridge. Livrées à ce téléphone quand il ne regarde pas activement une session."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Richiede una chiave APNs configurata sul tuo bridge. Le notifiche arrivano su questo telefono quando non sta osservando attivamente una sessione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブリッジ側に APNs キーの設定が必要です。この iPhone でセッションを開いて見ていないときに配信されます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Requer uma chave APNs configurada no seu bridge. Entregue a este telefone quando ele não está acompanhando uma sessão ativamente."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "需要在桥接上配置 APNs 密钥。当这台手机未在实时查看会话时，通知会推送到手机上。"
          }
        }
      }
    },
    "Reusable prompts you can tap to send from a session.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wiederverwendbare Prompts, die Sie aus einer Session heraus per Tipp senden können."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Prompts reutilizables que puedes tocar para enviarlos desde una sesión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Des prompts réutilisables à envoyer d'un simple toucher depuis une session."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Prompt riutilizzabili che puoi toccare per inviarli da una sessione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "セッションからタップして送信できる、再利用可能なプロンプトです。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Prompts reutilizáveis que você pode tocar para enviar de uma sessão."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可复用的提示词，在会话中点按即可发送。"
          }
        }
      }
    },
    "Reverts every modified file and deletes untracked ones in %@. This cannot be undone.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Setzt alle geänderten Dateien in %@ zurück und löscht untracked Dateien. Das kann nicht rückgängig gemacht werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Revierte todos los archivos modificados y elimina los no rastreados en %@. Esto no se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rétablit chaque fichier modifié et supprime les fichiers non suivis dans %@. C'est irréversible."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ripristina ogni file modificato ed elimina quelli non tracciati in %@. Questa operazione non può essere annullata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 内のすべての変更済みファイルを元に戻し、未追跡のファイルを削除します。この操作は取り消せません。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Reverte todos os arquivos modificados e apaga os não rastreados em %@. Isso não pode ser desfeito."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "还原 %@ 中所有已修改的文件，并删除未跟踪的文件。此操作无法撤销。"
          }
        }
      }
    },
    "Run a prompt automatically — every morning, weekdays, whenever.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einen Prompt automatisch ausführen — jeden Morgen, wochentags, wann immer Sie wollen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ejecuta un prompt automáticamente — cada mañana, los días laborables, cuando quieras."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lancez un prompt automatiquement — chaque matin, en semaine, quand vous voulez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Esegui un prompt automaticamente — ogni mattina, nei giorni feriali, quando vuoi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プロンプトを自動で実行できます — 毎朝でも、平日だけでも、好きなタイミングでも。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Execute um prompt automaticamente — toda manhã, em dias úteis, quando quiser."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自动运行提示词——每天早上、工作日，随你安排。"
          }
        }
      }
    },
    "Run Grok once on your computer. It opens your browser to sign in with your xAI account, then remembers you.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Führen Sie Grok einmal auf Ihrem Computer aus. Es öffnet den Browser zur Anmeldung mit Ihrem xAI-Account — danach bleiben Sie angemeldet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ejecuta Grok una vez en tu ordenador. Abrirá el navegador para iniciar sesión con tu cuenta de xAI y después te recordará."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lancez Grok une fois sur votre ordinateur. Votre navigateur s'ouvre pour vous connecter avec votre compte xAI, puis il se souvient de vous."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Esegui Grok una volta sul tuo computer. Aprirà il browser per accedere con il tuo account xAI, poi ti ricorderà."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コンピュータで一度 Grok を実行してください。ブラウザが開いて xAI アカウントでサインインすると、次回からは自動で認識されます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Execute o Grok uma vez no seu computador. Ele abre o navegador para você iniciar sessão com sua conta xAI e depois lembra de você."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
