          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Grok está ocioso. Sessões: %lld."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok 空闲中。你有 %lld 个会话。"
          }
        }
      }
    },
    "Grok is working on %@%@.": {
      "localizations": {
