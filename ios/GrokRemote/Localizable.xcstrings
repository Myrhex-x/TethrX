            "value": "Grok 正在处理 %@%@。"
          }
        }
      }
    },
    "Grok only runs /%@ inside its own terminal, so it does nothing from here.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok führt /%@ nur im eigenen Terminal aus — von hier bewirkt es nichts."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok solo ejecuta /%@ dentro de su propio terminal, así que desde aquí no hace nada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok n'exécute /%@ que dans son propre terminal, donc cela ne fait rien depuis ici."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok esegue /%@ solo nel proprio terminale, quindi da qui non fa nulla."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "/%@ は Grok 自身のターミナル内でのみ実行されるため、ここから送っても何も起こりません。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Grok só executa /%@ dentro do próprio terminal, então não faz nada a partir daqui."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok 只会在自己的终端里运行 /%@，因此在这里不会有任何效果。"
          }
        }
      }
    },
    "Grok will summarize the conversation (uses some tokens), then a new session opens seeded with that summary.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok fasst die Unterhaltung zusammen (verbraucht einige Tokens), dann öffnet sich eine neue Session, die mit dieser Zusammenfassung startet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok resumirá la conversación (consume algunos tokens) y luego se abrirá una sesión nueva a partir de ese resumen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok va résumer la conversation (cela consomme des tokens), puis une nouvelle session s'ouvre, amorcée avec ce résumé."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok riassumerà la conversazione (consuma qualche token), poi si aprirà una nuova sessione basata su quel riassunto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok が会話を要約し（トークンを少し消費します）、その要約を引き継いだ新しいセッションが開きます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Grok vai resumir a conversa (usa alguns tokens) e uma nova sessão será aberta a partir desse resumo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok 会先总结这段对话（会消耗一些 token），然后打开一个以该摘要为起点的新会话。"
          }
        }
      }
    },
    "Grok will summarize this conversation (uses some tokens) so the new session starts with the same context. This session keeps running as it is.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok résumera cette conversation (cela consomme des tokens) pour que la nouvelle session démarre avec le même contexte. Cette session continue telle quelle."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok resumirá esta conversación (consume algunos tokens) para que la nueva sesión empiece con el mismo contexto. Esta sesión sigue como está."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok fasst diese Unterhaltung zusammen (verbraucht Tokens), damit die neue Sitzung denselben Kontext hat. Diese Sitzung läuft unverändert weiter."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok riassumerà questa conversazione (consuma alcuni token) così la nuova sessione parte dallo stesso contesto. Questa sessione continua invariata."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Grok vai resumir esta conversa (consome alguns tokens) para que a nova sessão comece com o mesmo contexto. Esta sessão continua como está."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Grokがこの会話を要約し（トークンを少し消費します）、新しいセッションが同じ文脈から始まります。このセッションはそのまま動き続けます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok 会总结此对话（会消耗一些 token），让新会话拥有相同的上下文。当前会话保持原样继续运行。"
          }
        }
      }
    },
    "Grok writes a handoff summary of this conversation, and a fresh session starts from it. This one stays untouched.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok schreibt eine Übergabe-Zusammenfassung dieser Unterhaltung, und eine neue Session startet daraus. Diese hier bleibt unverändert."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok escribe un resumen de traspaso de esta conversación y una sesión nueva parte de él. Esta queda intacta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok rédige un résumé de passation de cette conversation, et une nouvelle session en repart. Celle-ci reste intacte."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok scrive un riassunto di passaggio di questa conversazione e da lì parte una nuova sessione. Questa resta intatta."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok がこの会話の引き継ぎ要約を書き、それをもとに新しいセッションが始まります。この会話はそのまま残ります。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Grok escreve um resumo de transição desta conversa, e uma nova sessão começa a partir dele. Esta permanece intacta."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok 会为这段对话撰写交接摘要，并从该摘要开启一个全新会话。当前会话保持不变。"
          }
        }
      }
    },
