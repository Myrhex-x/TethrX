      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Créer"
          }
        }
      }
    },
    "Then use the ••• button on any session to move it in.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez ensuite le bouton ••• d'une session pour l'y déplacer."
          }
        }
      }
    },
    "RUNNING NOW": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "EN COURS"
          }
        }
      }
    },
    "RUNNING": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "EN COURS"
          }
        }
      }
    },
    "FOUND IN CONVERSATIONS": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "TROUVÉ DANS LES CONVERSATIONS"
          }
        }
      }
    },
    "Sample data — nothing is connected.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
