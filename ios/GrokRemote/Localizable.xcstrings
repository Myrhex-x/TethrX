    "Grok drafts a plan to approve first": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok entwirft zuerst einen Plan zur Genehmigung"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok redacta primero un plan para que lo apruebes"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok rédige d'abord un plan à approuver"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok prepara prima un piano da approvare"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok がまずプランを作成し、承認を求めます"
          }
        },
        "pt-BR": {
          "stringUnit": {
