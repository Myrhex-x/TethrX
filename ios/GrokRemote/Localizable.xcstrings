    "Add computer": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajouter un ordinateur"
          }
        }
      }
    },
    "On the other computer, start the bridge and open its pairing page, then scan the code below.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sur l'autre ordinateur, démarrez le bridge et ouvrez sa page d'appairage, puis scannez le code ci-dessous."
          }
        }
      }
    },
    "NEARBY": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "À PROXIMITÉ"
          }
        }
      }
    },
    "Found on your network. Tap to fill the address — then enter that computer's token.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Trouvés sur votre réseau. Touchez pour remplir l'adresse — puis saisissez le jeton de cet ordinateur."
          }
        }
      }
    },
    "ADD COMPUTER": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "AJOUTER L'ORDINATEUR"
          }
        }
      }
    },
    "Adding a computer switches to it. Your other computers stay paired — swap between them any time.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajouter un ordinateur bascule dessus. Les autres restent appairés — changez à tout moment."
          }
        }
      }
    },
    "Couldn't reach that computer. Check the address and that its bridge is running.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de joindre cet ordinateur. Vérifiez l'adresse et que son bridge est lancé."
          }
        }
      }
    },
