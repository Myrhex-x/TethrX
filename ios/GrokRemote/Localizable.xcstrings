    },
    "Exit": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quitter"
          }
        }
      }
    },
    "Your bridge needs an update": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre bridge doit être mis à jour"
          }
        }
      }
    },
    "This version of the app needs bridge %@ or newer. On your computer, run:": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette version de l'app nécessite le bridge %@ ou plus récent. Sur votre ordinateur, lancez :"
          }
        }
      }
    },
    "Then restart the bridge and reconnect. Chat keeps working meanwhile; the newest features need the update.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Puis redémarrez le bridge et reconnectez-vous. La discussion continue de fonctionner ; les nouveautés nécessitent la mise à jour."
          }
        }
      }
    },
    "Pick a session": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez une session"
          }
        }
      }
    },
    "DISCONNECTED": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "DÉCONNECTÉ"
          }
        }
      }
    },
    "Settings": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Réglages"
          }
        }
      }
    },
    "Done": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "OK"
          }
        }
      }
    },
