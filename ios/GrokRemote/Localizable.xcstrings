    "To dictate messages, allow Microphone and Speech Recognition for TethrX in Settings.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Um Nachrichten zu diktieren, erlauben Sie TethrX in den Einstellungen Mikrofon und Spracherkennung."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Para dictar mensajes, permite Micrófono y Reconocimiento de voz para TethrX en Ajustes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pour dicter des messages, autorisez le micro et la reconnaissance vocale pour TethrX dans Réglages."
          }
        },
        "it": {
          "stringUnit": {
