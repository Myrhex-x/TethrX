    "Now install Tailscale from the App Store on this phone and sign in with the same account you just used on your computer. Using the same account on both is what links the two devices.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Installieren Sie Tailscale nun aus dem App Store auf diesem iPhone und melden Sie sich mit demselben Account an, den Sie gerade auf Ihrem Computer verwendet haben. Derselbe Account auf beiden Geräten ist es, was die zwei verknüpft."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ahora instala Tailscale desde el App Store en este teléfono e inicia sesión con la misma cuenta que acabas de usar en tu ordenador. Usar la misma cuenta en ambos es lo que vincula los dos dispositivos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Installez maintenant Tailscale depuis l'App Store sur ce téléphone et connectez-vous avec le même compte que sur votre ordinateur. C'est ce compte commun qui relie les deux appareils."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ora installa Tailscale dall'App Store su questo telefono e accedi con lo stesso account appena usato sul computer. Usare lo stesso account su entrambi è ciò che collega i due dispositivi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "次に、この iPhone に App Store から Tailscale をインストールし、先ほどコンピュータで使ったのと同じアカウントでサインインしてください。両方で同じアカウントを使うことで、2 台のデバイスがリンクされます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Agora instale o Tailscale da App Store neste telefone e inicie sessão com a mesma conta que você acabou de usar no computador. Usar a mesma conta nos dois é o que vincula os dispositivos."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "现在在这台手机上从 App Store 安装 Tailscale，并用你刚才在电脑上使用的同一账户登录。两端使用同一账户，正是将两台设备关联起来的方式。"
          }
        }
      }
    },
