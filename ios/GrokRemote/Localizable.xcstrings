    },
    "Grok only runs /%@ inside its own terminal, so it does nothing from here.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok n'exécute /%@ que dans son propre terminal, donc cela ne fait rien depuis ici."
          }
        }
      }
    },
    "That approval was no longer pending — grok isn't waiting on it.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette approbation n'était plus en attente — grok ne l'attend pas."
          }
        }
      }
    },
    "Couldn't send that decision. Check the connection and try again.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible d'envoyer cette décision. Vérifiez la connexion et réessayez."
