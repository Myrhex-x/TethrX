    "Runs on your computer's clock, even with this phone off. You'll get a push when it finishes.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Läuft nach der Uhr Ihres Computers, auch wenn dieses iPhone aus ist. Sie erhalten eine Push-Mitteilung, sobald es fertig ist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se ejecuta según el reloj de tu ordenador, incluso con este teléfono apagado. Recibirás una notificación push cuando termine."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "S'exécute à l'heure de votre ordinateur, même téléphone éteint. Vous recevrez une notification à la fin."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Segue l'orologio del tuo computer, anche a telefono spento. Riceverai una notifica push al termine."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この iPhone の電源が入っていなくても、コンピュータの時計に従って実行されます。完了するとプッシュ通知が届きます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Segue o relógio do seu computador, mesmo com este telefone desligado. Você recebe uma notificação push quando terminar."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按你电脑的时钟运行，即使手机关机也不受影响。完成后你会收到推送通知。"
          }
        }
      }
    },
