    "The bridge runs on Node.js 20 or newer. Install it from nodejs.org if you don't already have it.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Bridge läuft auf Node.js 20 oder neuer. Installieren Sie es von nodejs.org, falls noch nicht vorhanden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El bridge funciona con Node.js 20 o posterior. Instálalo desde nodejs.org si aún no lo tienes."
          }
        },
        "fr": {
