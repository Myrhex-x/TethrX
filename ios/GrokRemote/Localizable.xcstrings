    "This needs bridge 0.1.14 or newer — update it with npm i -g tethrx-bridge.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dafür ist Bridge 0.1.14 oder neuer nötig — aktualisieren Sie sie mit npm i -g tethrx-bridge."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto necesita el bridge 0.1.14 o posterior — actualízalo con npm i -g tethrx-bridge."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nécessite le bridge 0.1.14 ou plus récent — mettez-le à jour avec npm i -g tethrx-bridge."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Serve il bridge 0.1.14 o successivo — aggiornalo con npm i -g tethrx-bridge."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これにはブリッジ 0.1.14 以降が必要です — npm i -g tethrx-bridge でアップデートしてください。"
          }
        },
        "pt-BR": {
