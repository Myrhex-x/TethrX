    "Starts a second session that already knows everything this one knows — for trying another approach without losing this one.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Démarre une seconde session qui connaît déjà tout le contexte de celle-ci — pour essayer une autre approche sans perdre la session actuelle."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Inicia una segunda sesión que ya sabe todo lo que sabe esta, para probar otro enfoque sin perder la actual."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Startet eine zweite Sitzung, die alles weiß, was diese weiß — um einen anderen Weg zu versuchen, ohne diesen hier zu verlieren."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Avvia una seconda sessione che sa già tutto quello che sa questa, per provare un altro approccio senza perdere quello attuale."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Inicia uma segunda sessão que já sabe tudo o que esta sabe, para testar outra abordagem sem perder esta."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このセッションの内容をすべて引き継いだ2つ目のセッションを開始します。今のセッションを失わずに別の方法を試せます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
