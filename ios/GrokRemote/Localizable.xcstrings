    "Sends a prompt to your most recent Grok Build session, and leaves it running on your computer.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sendet einen Prompt an Ihre neueste Grok-Build-Session und lässt sie auf Ihrem Computer weiterlaufen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Envía un prompt a tu sesión más reciente de Grok Build y la deja ejecutándose en tu ordenador."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Envoie un prompt à votre session Grok Build la plus récente et la laisse tourner sur votre ordinateur."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Invia un prompt alla tua sessione Grok Build più recente e la lascia in esecuzione sul tuo computer."
          }
        },
        "ja": {
