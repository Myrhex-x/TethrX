    },
    "The task runs in this session — its folder, effort, and approval settings apply.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Aufgabe läuft in dieser Session — deren Ordner, Aufwand und Genehmigungseinstellungen gelten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La tarea se ejecuta en esta sesión — se aplican su carpeta, su esfuerzo y sus ajustes de aprobación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La tâche s'exécute dans cette session — son dossier, son effort et ses approbations s'appliquent."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'attività viene eseguita in questa sessione — si applicano la sua cartella, lo sforzo e le impostazioni di approvazione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "タスクはこのセッション内で実行されます — セッションのフォルダ、推論強度、承認設定が適用されます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
