            "state": "translated",
            "value": "Grok 会先草拟一份计划供你批准"
          }
        }
      }
    },
    "Grok is already working on something. Try again once it's finished.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok arbeitet bereits an etwas. Versuchen Sie es erneut, sobald Grok fertig ist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok ya está trabajando en algo. Vuelve a intentarlo cuando termine."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok travaille déjà sur quelque chose. Réessayez quand il aura terminé."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok sta già lavorando a qualcosa. Riprova quando avrà finito."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok は現在ほかの作業中です。完了してから、もう一度お試しください。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Grok já está trabalhando em algo. Tente novamente quando ele terminar."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok 正在处理其他任务。等它完成后再试。"
          }
        }
      }
    },
    "Grok is idle. You have %lld session%@.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok ist im Leerlauf. Sie haben %lld Session%@."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Grok is idle. You have %1$lld session%2$@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok está inactivo. Sesiones: %lld."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok est inactif. Vous avez %lld session%@."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok è inattivo. Sessioni: %lld."
          }
        },
        "ja": {
          "stringUnit": {
