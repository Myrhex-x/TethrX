    "Get alerted when Grok finishes a turn or needs approval — even with the app closed": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Werden Sie benachrichtigt, wenn Grok einen Turn abschließt oder eine Genehmigung braucht — auch bei geschlossener App"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Recibe un aviso cuando Grok termina un turno o necesita aprobación — incluso con la app cerrada"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Soyez prévenu quand Grok termine ou attend une approbation — même app fermée"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ricevi un avviso quando Grok termina un turno o serve un'approvazione — anche ad app chiusa"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Grok がターンを終えたときや承認が必要なとき、アプリを閉じていても通知を受け取れます"
          }
        },
        "pt-BR": {
          "stringUnit": {
