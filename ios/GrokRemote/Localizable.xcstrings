    "Reverts every modified file and deletes untracked ones in %@. This cannot be undone.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rétablit chaque fichier modifié et supprime les fichiers non suivis dans %@. C'est irréversible."
          }
        }
      }
    },
    "Commit failed. Check that git is configured (user.name / user.email) on that computer.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le commit a échoué. Vérifiez que git est configuré (user.name / user.email) sur cet ordinateur."
