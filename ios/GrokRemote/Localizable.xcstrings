    "Turn on the camera for TethrX in Settings to scan the pairing code — or just type the address and token by hand.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktivieren Sie die Kamera für TethrX in den Einstellungen, um den Pairing-Code zu scannen — oder geben Sie Adresse und Token einfach von Hand ein."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activa la cámara para TethrX en Ajustes para escanear el código de enlace — o simplemente escribe la dirección y el token a mano."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez l’appareil photo pour TethrX dans Réglages afin de scanner le code d’appairage — ou saisissez simplement l’adresse et le jeton à la main."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Attiva la fotocamera per TethrX in Impostazioni per scansionare il codice di abbinamento — oppure digita a mano indirizzo e token."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ペアリングコードをスキャンするには、設定で TethrX のカメラをオンにしてください — アドレスとトークンを手入力しても構いません。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ative a câmera para o TethrX nos Ajustes para escanear o código de pareamento — ou digite o endereço e o token manualmente."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在设置中为 TethrX 开启相机权限以扫描配对码——或直接手动输入地址和令牌。"
          }
        }
      }
    },
